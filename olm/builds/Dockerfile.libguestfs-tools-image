ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG PACKAGE
RUN useradd -d /home/nonroot-user -U -u 1001 -s /bin/bash nonroot-user
RUN sh -c "dnf config-manager --enable ol9_appstream --enable ol9_UEKR7 --enable ol9_kvm_utils && \
    dnf install -y "$PACKAGE" && \
    dnf clean all"
USER 1001

ENTRYPOINT ["/entrypoint.sh"]
